 function formatTimeRange(start, end) {
   if (!(start instanceof Date) || Number.isNaN(start.getTime())) return "--:--";
   const fmt = (d) =>
     d.toLocaleTimeString([], { hour: "numeric", minute: "2-digit" }).replace(" ", "");
