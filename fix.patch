 def _mask_id(value: str | None) -> str:
     token = (value or "").strip()
     if not token:
         return ""
     if len(token) <= 10:
         return f"{token[:3]}…{token[-2:]}"
     return f"{token[:6]}…{token[-4:]}"
 
 
