 const getCleanApiErrorMessage = (err, fallbackMessage) => {
   const detail =
     err?.response?.data?.detail ||
     err?.response?.data?.message ||
     err?.message;
   if (!detail) return fallbackMessage;
   if (typeof detail === "string") return detail;
   return fallbackMessage;
 };
 
